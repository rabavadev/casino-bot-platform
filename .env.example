# PostgreSQL connection (Supabase or any managed Postgres)
# Supabase: Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Public HTTPS base URL — Telegram REQUIRES https for webhooks.
# Local dev: run `cloudflared tunnel --url http://localhost:3000` (or ngrok)
# and paste the https URL it gives you here, then restart the server.
PUBLIC_BASE_URL=https://your-tunnel-or-domain.com

# 32-byte hex key for AES-256-GCM bot-token encryption.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENC_KEY=

# Bearer key protecting the admin API (swap for real dashboard auth later)
ADMIN_API_KEY=change-me

# Salt mixed into click IP hashing (privacy + dedupe)
IP_HASH_SALT=change-me-too

PORT=3000
